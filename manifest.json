{
  "manifest_version": 3,
  "name": "Gmail Sidebar Cleaner",
  "description": "Sidebar actions for unsubscribe, selecting similar emails, and archiving in Gmail.",
  "version": "1.0.0",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://mail.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
